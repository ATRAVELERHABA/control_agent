{
  "productName": "AI-Universal-Assistant",
  "version": "0.1.0",
  "identifier": "com.aiuniversalassistant.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI-Universal-Assistant",
        "width": 960,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "./bundled-resources/.skills/": ".skills/",
      "./bundled-resources/control_agent/scripts/": "control_agent/scripts/",
      "./bundled-resources/control_agent/site-packages/": "control_agent/site-packages/",
      "./bundled-resources/python-runtime/": "python-runtime/",
      "./bundled-resources/.env.example": ".env.example"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
