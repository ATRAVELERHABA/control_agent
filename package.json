{
  "name": "ai-universal-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1420",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepare:windows-bundle": "powershell -ExecutionPolicy Bypass -File .\\scripts\\prepare_windows_bundle.ps1",
    "prepare:linux-bundle": "sh ./scripts/prepare_linux_bundle.sh",
    "tauri": "tauri",
    "tauri:build:installer": "npm run prepare:windows-bundle && tauri build",
    "tauri:build:linux": "tauri build",
    "tauri:build:linux:deb": "tauri build -b deb",
    "tauri:build:linux:appimage": "tauri build -b appimage"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@tauri-apps/api": "^2",
    "antd": "^5.27.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
