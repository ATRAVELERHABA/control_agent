# =========================
# Online provider (backend)
# =========================
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_API_KEY=
OPENAI_VISION_MODEL=
OPENAI_AUDIO_MODEL=

# 如果 OPENAI_BASE_URL 为空，则在线模式会自动回退到：
# https://dashscope.aliyuncs.com/compatible-mode/v1
# model = qwen3-max
ALIYUN_API_KEY=
ALIYUN_MODEL=qwen3-max
ALIYUN_VISION_MODEL=qwen3.6-plus
ALIYUN_AUDIO_MODEL=qwen3-asr-flash

# ========================
# Local provider (backend)
# ========================
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=
OLLAMA_API_KEY=
OLLAMA_VISION_MODEL=

# ==========================
# Local multimodal helpers
# ==========================
LOCAL_AUDIO_MODEL=base

# ==========================
# DingTalk remote relay
# ==========================
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_AGENT_MODE=online
DINGTALK_ALLOWED_SENDERS=
DINGTALK_ALLOWED_CHATS=
DINGTALK_ENABLE_REMOTE_COMMANDS=false
DINGTALK_ENABLE_REMOTE_SEARCH=false
DINGTALK_SEND_PROCESSING_REPLY=true
DINGTALK_PROCESSING_REPLY_TEXT=已收到，正在处理，请稍候。
DINGTALK_ALLOWED_COMMAND_PREFIXES=
