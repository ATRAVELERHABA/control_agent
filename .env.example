# =========================
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_API_KEY=
OPENAI_VISION_MODEL=
OPENAI_AUDIO_MODEL=

# 如果 OPENAI_BASE_URL 为空，则在线模式会自动回退到：
