ALIYUN_MODEL=qwen3-max
ALIYUN_VISION_MODEL=qwen3.6-plus
ALIYUN_AUDIO_MODEL=qwen3-asr-flash

# ========================
# Local provider (backend)
# ========================
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=
OLLAMA_API_KEY=
OLLAMA_VISION_MODEL=

# ==========================
# Local multimodal helpers
